<routes>
  <route id="r_main" edges="nw_to_sw sw_to_se se_to_ne ne_to_nw"/>

  <!-- Emergency lead vehicle (incident source) -->
  <vType id="EmergencyLead" vClass="emergency" accel="4.0" decel="7.0" emergencyDecel="9.0" sigma="0.0" tau="0.6" minGap="1.0" maxSpeed="24.0"/>

  <!-- Followers used in the demonstrator -->
  <vType id="FollowerFlow" accel="3.5" decel="4.5" emergencyDecel="6.5" sigma="0.0" tau="0.7" minGap="0.9" maxSpeed="22.0"
         lcStrategic="0.0" lcCooperative="0.0" lcSpeedGain="0.0" lcKeepRight="0.0"/>
  <vType id="BackgroundFlow" accel="2.8" decel="5.0" emergencyDecel="7.0" sigma="0.0" tau="1.1" minGap="2.0" maxSpeed="16.0"
         lcStrategic="0.0" lcCooperative="0.0" lcSpeedGain="0.0" lcKeepRight="0.0"/>

  <!-- Truck lane (lane 0): exactly three followers behind veh2 -->
  <vehicle id="veh2"  type="EmergencyLead" route="r_main" depart="0.2" departLane="0" departPos="120" departSpeed="21"/>
  <vehicle id="veh3"  type="FollowerFlow" route="r_main" depart="0.2" departLane="0" departPos="100" departSpeed="20"/>
  <vehicle id="veh4"  type="FollowerFlow" route="r_main" depart="0.2" departLane="0" departPos="85"  departSpeed="20"/>
  <vehicle id="veh5"  type="FollowerFlow" route="r_main" depart="0.2" departLane="0" departPos="70"  departSpeed="20"/>

  <!-- Adjacent lane (lane 1): staggered, slower background flow to preserve merge windows -->
  <vehicle id="veh6"  type="BackgroundFlow" route="r_main" depart="0.2"  departLane="1" departPos="30" departSpeed="15"/>
  <vehicle id="veh7"  type="BackgroundFlow" route="r_main" depart="0.2"  departLane="1" departPos="10" departSpeed="15"/>
  <vehicle id="veh8"  type="BackgroundFlow" route="r_main" depart="3.0"  departLane="1" departPos="0"  departSpeed="15"/>
  <vehicle id="veh9"  type="BackgroundFlow" route="r_main" depart="6.0"  departLane="1" departPos="0"  departSpeed="15"/>
  <vehicle id="veh10" type="BackgroundFlow" route="r_main" depart="9.0"  departLane="1" departPos="0"  departSpeed="15"/>
  <vehicle id="veh11" type="BackgroundFlow" route="r_main" depart="12.0" departLane="1" departPos="0"  departSpeed="15"/>
  <vehicle id="veh12" type="BackgroundFlow" route="r_main" depart="15.0" departLane="1" departPos="0"  departSpeed="15"/>
</routes>
